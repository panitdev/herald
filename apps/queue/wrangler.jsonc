// apps/queue/wrangler.jsonc
{
  "name": "herald-queue",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-25",

  "d1_databases": [
    {
      "migrations_dir": "../../migrations/",
      "binding": "DB",
      "database_name": "herald-database",
      "database_id": "6e68d423-6ef3-47a4-8e55-87322c077c93"
    }
  ],

  "r2_buckets": [
    {
      "binding": "MAIL_BUCKET",
      "bucket_name": "herald-mail"
    }
  ],

  "queues": {
    "consumers": [
      {
        "queue": "herald-ingest",
        "max_batch_size": 10,
        "max_batch_timeout": 5
      }
    ]
  }
}

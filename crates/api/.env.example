# Postgres connection string used by the API.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/herald

# Shared secret for internal API/worker calls. Use a strong secret in deployed environments.
HERALD_INTERNAL_SECRET=change-me

# Worker receiver endpoint used for inbound mail recovery and handoff.
HERALD_WORKER_URL=http://127.0.0.1:8787

# Ory Kratos public endpoint.
KRATOS_PUBLIC_URL=http://localhost:4433

# Mail domain used for address validation and routing.
MAIL_DOMAIN=panit.dev

# Filesystem blob storage root.
BLOB_STORE_ROOT=./data/blobs

# API bind port.
API_PORT=3001

# Snowflake IDs. Keep each deployed API instance unique.
SNOWFLAKE_MACHINE_ID=1
SNOWFLAKE_NODE_ID=1

# Optional shared (system) outbound email sender. Entirely optional: with none
# of these set, herald-api ships with no provider key and users register their
# own senders via the API. Resend takes precedence when both are configured.
#
# Resend:
# RESEND_API_KEY=re_your_key
#
# AWS SES (all three required):
# AWS_SES_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

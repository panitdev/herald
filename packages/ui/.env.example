# Public API base URL. Vite inlines this value at build time for static builds.
# The Docker/Bun production server also reads it at runtime and injects it into
# the rendered HTML.
VITE_API_URL=http://localhost:3001

# Public mail domain shown and validated by the UI.
VITE_MAIL_DOMAIN=panit.dev

# Ory Kratos public endpoint. Leave empty to disable Kratos redirects locally.
VITE_KRATOS_PUBLIC_URL=http://localhost:4433

# Bun production server bind settings.
HOST=0.0.0.0
PORT=3000
